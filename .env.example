# .env.example
# Esta es una plantilla para las variables de entorno.
# Renombra este archivo a .env y añade tus propias claves si deseas usarlas por defecto en el servidor.
# NOTA: En la versión de GitHub Pages (Client-Side), los usuarios ingresarán sus claves en la interfaz de usuario (Settings).

# Clave de Google Gemini (Opcional si se usa la interfaz de usuario)
GEMINI_API_KEY=tu_clave_de_gemini_aqui
